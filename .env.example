REACT_APP_SERVER_URL = "BACKEND_URL_PLACEHOLDER"

# OpenRouter — server-side only, do NOT prefix with VITE_ (keeps it out of the bundle).
# Used by POST /api/translate to AI-translate localization fields into every language.
OPENROUTER_API_KEY = "OPENROUTER_API_KEY_PLACEHOLDER"
OPENROUTER_MODEL = "google/gemini-2.5-flash"

# Storefront base URL for the hero live-preview iframe (/preview/hero).
# Set per environment in Vercel (project grbpwr-admin-client):
#   Production           -> https://grbpwr.com
#   Preview (beta branch)-> https://beta.grbpwr.com
#   Development          -> https://grbpwr.com
# Local `yarn dev` uses this file (or the code fallback http://localhost:3000) — run the
# storefront locally, or set a value here. The admin origin must be allowlisted on the
# storefront's /preview/* frame-ancestors + ADMIN_ORIGINS, else the iframe is blocked.
VITE_STOREFRONT_URL = "http://localhost:3000"