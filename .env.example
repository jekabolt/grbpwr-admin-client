REACT_APP_SERVER_URL = "BACKEND_URL_PLACEHOLDER"

# OpenRouter — server-side only, do NOT prefix with VITE_ (keeps it out of the bundle).
# Used by POST /api/translate to AI-translate localization fields into every language.
OPENROUTER_API_KEY = "OPENROUTER_API_KEY_PLACEHOLDER"
OPENROUTER_MODEL = "google/gemini-2.5-flash"